---
import { site, nav } from '../data/site';
import Icon from './Icon.astro';
import Logo from './Logo.astro';
import TopBar from './TopBar.astro';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const links = [{ label: 'Home', href: '/' }, ...nav];
---

<TopBar />

<header class="sticky top-0 z-50 border-b border-white/10 bg-ink/95 text-white backdrop-blur supports-[backdrop-filter]:bg-ink/80">
  <div class="container-px flex h-16 items-center justify-between gap-4 sm:h-[4.5rem]">
    <!-- Brand -->
    <a href="/" aria-label={`${site.name} home`}>
      <Logo tone="dark" />
    </a>

    <!-- Primary nav -->
    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        links.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-semibold uppercase tracking-wide transition-colors hover:text-brand-light',
              isActive(item.href) ? 'text-brand-light' : 'text-white/85',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Utilities -->
    <div class="flex items-center gap-1 sm:gap-2">
      <button
        type="button"
        class="hidden items-center gap-2 rounded-md border border-white/15 px-3 py-1.5 text-xs font-medium text-white/70 transition-colors hover:border-white/40 hover:text-white lg:flex"
        aria-label="Search tires"
      >
        <Icon name="search" class="h-4 w-4" />
        <span>Search</span>
        <kbd class="rounded bg-white/10 px-1.5 py-0.5 font-sans text-[10px] font-semibold">⌘K</kbd>
      </button>
      <a href="/account" class="hidden h-9 w-9 items-center justify-center rounded-md text-white/85 hover:bg-white/10 sm:flex" aria-label="Account">
        <Icon name="user" class="h-5 w-5" />
      </a>
      <a href="/shop" class="relative flex h-9 w-9 items-center justify-center rounded-md text-white/85 hover:bg-white/10" aria-label="Cart">
        <Icon name="cart" class="h-5 w-5" />
      </a>
      <a href="/shop" class="btn-primary ml-1 hidden px-4 py-2 text-sm sm:inline-flex">Shop tires</a>

      <button
        type="button"
        id="menu-toggle"
        class="ml-1 inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/20 md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden border-t border-white/10 md:hidden" aria-label="Mobile">
    <div class="container-px flex flex-col gap-1 py-4">
      {
        links.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-2.5 text-base font-semibold uppercase tracking-wide',
              isActive(item.href) ? 'bg-brand text-white' : 'text-white/90 hover:bg-white/10',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a href="/shop" class="btn-primary mt-2">Shop tires</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
