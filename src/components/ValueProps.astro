---
import { valueProps, site } from '../data/site';
import Icon from './Icon.astro';
---

<section class="section bg-white">
  <div class="container-px">
    <div class="max-w-3xl">
      <p class="eyebrow">The Axel promise</p>
      <h2 class="heading mt-3 text-4xl sm:text-5xl">We built this because tire shopping shouldn’t hurt.</h2>
      <p class="mt-5 text-lg leading-relaxed text-steel">
        Every other tire shop in {site.city} makes you wait on hold to learn whether they
        have your size — then upsells you a brake job. Not us.
      </p>
      <p class="mt-3 text-sm font-semibold uppercase tracking-widest text-brand">
        {site.city} · Est. {site.established} · Family-owned
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        valueProps.map((prop) => (
          <div class="rounded-xl border border-black/10 bg-mist p-6 transition-colors hover:border-brand/40">
            <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand text-white">
              <Icon name={prop.icon} class="h-6 w-6" />
            </span>
            <h3 class="heading mt-4 text-xl">{prop.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-steel">{prop.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
