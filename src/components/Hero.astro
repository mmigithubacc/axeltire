---
import { site } from '../data/site';
import Icon from './Icon.astro';
import SizeFinder from './SizeFinder.astro';

const features = [
  { top: 'All-in', bottom: 'Pricing' },
  { top: 'Real-time', bottom: 'Inventory' },
  { top: 'B2B', bottom: '+ Retail' },
];
---

<section class="relative overflow-hidden bg-ink text-white">
  <!-- Background accents -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -right-32 -top-32 h-96 w-96 rounded-full bg-brand/20 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 h-72 w-72 rounded-full bg-brand/10 blur-3xl"></div>
    <div
      class="absolute inset-0 opacity-[0.15]"
      style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 32px 32px;"
    >
    </div>
  </div>

  <div class="container-px relative grid gap-12 py-16 sm:py-24 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1.5 text-xs font-bold uppercase tracking-widest">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        </span>
        Live · Edmonton stock
      </span>

      <h1 class="heading mt-6 text-5xl sm:text-6xl lg:text-7xl">
        Honest tires.<br /><span class="text-brand-light">No upsells.</span>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/75">
        Wholesale and retail in {site.city} — the price you see covers tire, install,
        balance and disposal. That’s it.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/shop" class="btn-primary">
          Shop tires
          <Icon name="arrow" class="h-5 w-5" />
        </a>
        <a href="/book" class="btn-outline">Book install</a>
      </div>

      <dl class="mt-10 flex flex-wrap gap-x-8 gap-y-4">
        {
          features.map((f) => (
            <div>
              <dt class="font-display text-xl font-bold text-white">{f.top}</dt>
              <dd class="text-sm uppercase tracking-widest text-white/50">{f.bottom}</dd>
            </div>
          ))
        }
      </dl>

      <p class="mt-6 text-sm text-white/50">
        <span class="font-semibold text-brand-light">Best seller</span> · Haida Winter HD617
      </p>
    </div>

    <div class="lg:pl-6">
      <SizeFinder variant="dark" />
    </div>
  </div>
</section>
