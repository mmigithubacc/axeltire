---
/**
 * Detailed vector tire + alloy wheel. Used in product cards and the hero.
 * Purely CSS/SVG so it scales crisply at any size and needs no image assets.
 */
interface Props {
  class?: string;
}
const { class: className = 'h-28 w-28' } = Astro.props;

const TREADS = Array.from({ length: 48 }, (_, i) => i * (360 / 48));
const WINDOWS = [0, 72, 144, 216, 288];
const LUGS = [36, 108, 180, 252, 324];
---

<svg class={className} viewBox="0 0 200 200" fill="none" aria-hidden="true">
  <defs>
    <radialGradient id="tire-rubber" cx="50%" cy="40%" r="65%">
      <stop offset="0%" stop-color="#3b3e44" />
      <stop offset="55%" stop-color="#17181b" />
      <stop offset="100%" stop-color="#08090b" />
    </radialGradient>
    <linearGradient id="tire-rim" x1="18%" y1="10%" x2="85%" y2="92%">
      <stop offset="0%" stop-color="#f4f6f9" />
      <stop offset="38%" stop-color="#cfd5dd" />
      <stop offset="70%" stop-color="#949aa3" />
      <stop offset="100%" stop-color="#6b7178" />
    </linearGradient>
    <radialGradient id="tire-hub" cx="42%" cy="38%" r="70%">
      <stop offset="0%" stop-color="#33373d" />
      <stop offset="100%" stop-color="#0c0d10" />
    </radialGradient>
  </defs>

  <!-- Rubber body -->
  <circle cx="100" cy="100" r="97" fill="url(#tire-rubber)" />

  <!-- Tread blocks -->
  {
    TREADS.map((a) => (
      <rect
        x="96"
        y="4"
        width="8"
        height="15"
        rx="2"
        fill="#25272b"
        transform={`rotate(${a} 100 100)`}
      />
    ))
  }
  <circle cx="100" cy="100" r="84" stroke="#0a0b0d" stroke-width="3" />
  <circle cx="100" cy="100" r="80" stroke="#34373c" stroke-width="1" />

  <!-- Sidewall -->
  <circle cx="100" cy="100" r="72" fill="#101114" />
  <circle cx="100" cy="100" r="66" fill="url(#tire-rubber)" stroke="#3a3d42" stroke-width="1" />

  <!-- Alloy face -->
  <circle cx="100" cy="100" r="60" fill="url(#tire-rim)" stroke="#5f656d" stroke-width="1.5" />

  <!-- Spoke windows (carve out a 5-spoke wheel) -->
  {
    WINDOWS.map((a) => (
      <rect
        x="91"
        y="20"
        width="18"
        height="36"
        rx="9"
        fill="#0c0d10"
        transform={`rotate(${a} 100 100)`}
      />
    ))
  }

  <!-- Hub + lug nuts -->
  <circle cx="100" cy="100" r="23" fill="url(#tire-hub)" stroke="#565b62" stroke-width="1.5" />
  {
    LUGS.map((a) => (
      <circle cx="100" cy="86" r="3.2" fill="#dce1e6" transform={`rotate(${a} 100 100)`} />
    ))
  }

  <!-- Center cap -->
  <circle cx="100" cy="100" r="11" fill="#14171c" stroke="#3a3d42" stroke-width="1" />
  <circle cx="100" cy="100" r="4.5" fill="#e11d2a" />

  <!-- Gloss highlight -->
  <path d="M44 60a72 72 0 0132-30" stroke="#ffffff" stroke-opacity="0.18" stroke-width="4" stroke-linecap="round" />
</svg>
