---
import type { Product } from '../data/products';
import { formatStock } from '../data/products';
import { site } from '../data/site';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const inStock = product.stock > 0;
---

<article class="group flex flex-col rounded-xl border border-black/10 bg-white p-5 transition-shadow hover:shadow-lg">
  <div class="flex items-center justify-between">
    <span class="text-xs font-bold uppercase tracking-widest text-steel">
      {product.brand} · {product.season}
    </span>
    {product.bestSeller && (
      <span class="rounded-full bg-brand/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-brand">
        Best seller
      </span>
    )}
  </div>

  <!-- Tire illustration -->
  <div class="my-5 flex justify-center">
    <div class="flex h-24 w-24 items-center justify-center rounded-full bg-ink text-white ring-8 ring-black/5">
      <div class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white/30">
        <span class="h-4 w-4 rounded-full bg-brand"></span>
      </div>
    </div>
  </div>

  <h3 class="font-display text-xl font-bold uppercase leading-tight text-ink">{product.model}</h3>
  <p class="mt-0.5 font-mono text-sm text-steel">{product.size}</p>

  <div class="mt-4 flex items-end justify-between border-t border-black/5 pt-4">
    <div>
      <span class="font-display text-3xl font-bold text-ink">${product.price}</span>
      <span class="block text-[11px] font-medium text-steel">all-in, per tire · {site.currency}</span>
    </div>
    <span
      class:list={[
        'flex items-center gap-1.5 text-xs font-semibold',
        inStock ? 'text-emerald-600' : 'text-steel',
      ]}
    >
      <span class:list={['h-2 w-2 rounded-full', inStock ? 'bg-emerald-500' : 'bg-gray-400']}></span>
      {inStock ? `${formatStock(product.stock)} in stock` : 'Out of stock'}
    </span>
  </div>

  <a
    href="/book"
    class="btn-dark mt-5 w-full py-2.5 text-sm group-hover:bg-brand group-hover:text-white"
  >
    Add & book install
  </a>
</article>
