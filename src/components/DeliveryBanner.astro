---
import { delivery, site } from '../data/site';
import Icon from './Icon.astro';
---

<section class="bg-brand text-white">
  <div class="container-px flex flex-col items-center justify-between gap-4 py-5 sm:flex-row">
    <div class="flex items-center gap-4">
      <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/15">
        <Icon name="truck" class="h-6 w-6" />
      </span>
      <p class="text-base font-semibold leading-tight sm:text-lg">
        We deliver in {site.city} — {delivery.minTires}-tire minimum.
        <span class="block text-sm font-normal text-white/85 sm:inline sm:text-base">
          Same all-in price, brought to your door.
        </span>
      </p>
    </div>
    <a
      href="/shop"
      class="shrink-0 rounded-lg bg-white px-5 py-2.5 text-sm font-bold text-brand transition-transform hover:-translate-y-0.5"
    >
      Shop &amp; get it delivered
    </a>
  </div>
</section>
