---
/**
 * Axel Tires wordmark. `tone` switches between the dark header and the
 * light footer. This is a CSS/SVG approximation of the brand logo — swap in
 * the official asset at /public/images/logo.svg when available.
 */
interface Props {
  tone?: 'dark' | 'light';
  class?: string;
}
const { tone = 'dark', class: className = '' } = Astro.props;
const text = tone === 'dark' ? 'text-white' : 'text-ink';
---

<span class:list={['inline-flex items-center gap-2', className]}>
  <!-- Tire mark -->
  <svg class="h-8 w-8 shrink-0 -rotate-6" viewBox="0 0 40 40" fill="none" aria-hidden="true">
    <circle cx="20" cy="20" r="18" fill="#14171c" />
    <circle cx="20" cy="20" r="9" fill="none" stroke="#ffffff" stroke-width="2" opacity="0.35" />
    <path d="M20 4a16 16 0 0114.6 9.5" stroke="#e11d2a" stroke-width="4" stroke-linecap="round" />
    <circle cx="20" cy="20" r="4" fill="#e11d2a" />
  </svg>
  <span class="flex flex-col leading-none">
    <span class:list={['font-display text-2xl font-extrabold italic uppercase tracking-tight', text]}>
      Axel
    </span>
    <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.35em] text-brand">
      Tires
    </span>
  </span>
</span>
