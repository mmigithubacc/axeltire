---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import { site, hours } from '../data/site';

const contactCards = [
  { icon: 'mail', title: 'Email', value: site.email, href: `mailto:${site.email}` },
  { icon: 'building', title: 'Dealers', value: 'dealers@axeltire.ca', href: 'mailto:dealers@axeltire.ca' },
  { icon: 'pin', title: 'Location', value: 'Edmonton, AB — exact address coming soon', href: null },
];
---

<Layout
  title="Contact — Edmonton Tire Shop"
  description="Contact Axel Tires in Edmonton — email, hours and location. Same-day replies during business hours. Delivery available on 2+ tires."
>
  <PageHeader eyebrow="Contact" title="We answer the phone.">
    Questions about a size, an order, or dealer access? Reach out — same-day
    replies during business hours.
  </PageHeader>

  <section class="section bg-mist">
    <div class="container-px grid gap-8 lg:grid-cols-[1fr_360px]">
      <!-- Message form -->
      <form class="rounded-2xl border border-black/10 bg-white p-6 sm:p-8" id="contact-form" data-email={site.email}>
        <h2 class="heading text-2xl text-ink">Send us a message</h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-semibold text-ink">Name<span class="text-brand">*</span></span>
            <input name="name" required class="form-field" />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink">Email<span class="text-brand">*</span></span>
            <input name="email" type="email" required class="form-field" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-semibold text-ink">Subject</span>
            <input name="subject" class="form-field" placeholder="Tire size, order, dealer access…" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-semibold text-ink">Message<span class="text-brand">*</span></span>
            <textarea name="message" rows="5" required class="form-field"></textarea>
          </label>
        </div>
        <button type="submit" class="btn-primary mt-6 w-full sm:w-auto">
          <Icon name="mail" class="h-5 w-5" />
          Send message
        </button>
      </form>

      <!-- Contact details -->
      <aside class="space-y-4">
        {
          contactCards.map((card) => (
            <div class="rounded-2xl border border-black/10 bg-white p-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
                <Icon name={card.icon} class="h-5 w-5" />
              </span>
              <h2 class="heading mt-3 text-lg">{card.title}</h2>
              {card.href ? (
                <a href={card.href} class="mt-1 block text-sm font-medium text-brand hover:text-brand-dark">
                  {card.value}
                </a>
              ) : (
                <p class="mt-1 text-sm text-steel">{card.value}</p>
              )}
            </div>
          ))
        }

        <div class="rounded-2xl border border-black/10 bg-white p-6">
          <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
            <Icon name="clock" class="h-5 w-5" />
          </span>
          <h2 class="heading mt-3 text-lg">Hours</h2>
          <dl class="mt-2 space-y-1.5 text-sm">
            {
              hours.map((h) => (
                <div class="flex justify-between gap-4">
                  <dt class="text-steel">{h.day}</dt>
                  <dd class="font-medium text-ink">{h.time}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </aside>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = form.dataset.email;
      const f = new FormData(form);
      const subject = (f.get('subject') as string) || 'Website enquiry';
      const body = [
        `Name: ${f.get('name') || ''}`,
        `Email: ${f.get('email') || ''}`,
        '',
        `${f.get('message') || ''}`,
      ].join('\n');
      location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</Layout>
