---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { isSupabaseConfigured } from '../lib/supabase';
import { site } from '../data/site';
---

<Layout title="My account" description="Sign in to order tires for delivery in Edmonton and track your orders." noindex>
  <PageHeader eyebrow="Account" title="Your account.">
    Sign in or create an account to order tires for delivery and track them.
  </PageHeader>

  <Breadcrumbs items={[{ label: 'Account', href: '/account' }]} />

  <section class="bg-mist py-10 sm:py-14">
    <div class="container-px max-w-4xl">
      {!isSupabaseConfigured && (
        <div class="rounded-2xl border border-amber-300 bg-amber-50 p-6 text-amber-900">
          Accounts aren’t available yet — the store is being set up. Please email
          <a href={`mailto:${site.email}`} class="font-semibold underline">{site.email}</a> to order.
        </div>
      )}

      <!-- Signed out: auth -->
      <form id="auth" class="hidden max-w-sm rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
        <p id="auth-note" class="hidden rounded-lg bg-brand/10 px-3 py-2 text-sm font-medium text-brand"></p>
        <h2 id="auth-title" class="heading mt-1 text-xl text-ink">Sign in</h2>
        <label class="mt-4 block">
          <span class="text-sm font-semibold text-ink">Email</span>
          <input name="email" type="email" required class="form-field" />
        </label>
        <label class="mt-3 block">
          <span class="text-sm font-semibold text-ink">Password</span>
          <input name="password" type="password" required minlength="6" class="form-field" />
        </label>
        <p id="auth-error" class="mt-3 hidden text-sm font-medium text-brand"></p>
        <p id="auth-ok" class="mt-3 hidden text-sm font-medium text-emerald-600"></p>
        <button type="submit" id="auth-submit" class="btn-primary mt-5 w-full">Sign in</button>
        <p class="mt-4 text-center text-sm text-steel">
          <span id="auth-toggle-text">New here?</span>
          <button type="button" id="auth-toggle" class="font-semibold text-brand">Create account</button>
        </p>
      </form>

      <!-- Signed in: account + orders -->
      <div id="account" class="hidden">
        <div class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-black/10 bg-white p-5">
          <p class="text-sm text-steel">Signed in as <span id="acct-email" class="font-semibold text-ink"></span></p>
          <div class="flex gap-2">
            <a href="/shop" class="btn-dark py-2 text-sm">Shop tires</a>
            <button id="acct-signout" class="rounded-lg border border-black/15 px-4 py-2 text-sm font-semibold text-steel hover:bg-mist">Sign out</button>
          </div>
        </div>

        <h2 class="heading mt-8 text-2xl text-ink">My orders</h2>
        <p id="orders-status" class="mt-1 text-sm text-steel"></p>
        <div id="orders" class="mt-3 space-y-2"></div>
      </div>
    </div>
  </section>

  <script>
    import { getSupabase } from '../lib/supabase';
    const sb = getSupabase();
    const $ = (id: string) => document.getElementById(id)!;

    if (sb) init();

    let mode: 'signin' | 'signup' = 'signin';

    async function init() {
      const authForm = $('auth') as HTMLFormElement;
      const params = new URLSearchParams(location.search);
      const next = params.get('next');
      if (params.get('reason') === 'order') {
        const note = $('auth-note');
        note.textContent = 'Sign in or create an account to place your order.';
        note.classList.remove('hidden');
      }

      const { data } = await sb!.auth.getSession();
      if (data.session) return showAccount();
      authForm.classList.remove('hidden');

      const setMode = (m: 'signin' | 'signup') => {
        mode = m;
        const up = m === 'signup';
        $('auth-title').textContent = up ? 'Create account' : 'Sign in';
        ($('auth-submit') as HTMLButtonElement).textContent = up ? 'Create account' : 'Sign in';
        $('auth-toggle-text').textContent = up ? 'Already have an account?' : 'New here?';
        ($('auth-toggle') as HTMLElement).textContent = up ? 'Sign in' : 'Create account';
        $('auth-error').classList.add('hidden');
        $('auth-ok').classList.add('hidden');
      };
      $('auth-toggle').addEventListener('click', () => setMode(mode === 'signin' ? 'signup' : 'signin'));

      // Guests arriving to place an order start on Create account.
      if (params.get('reason') === 'order') setMode('signup');

      authForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = new FormData(authForm);
        const email = String(f.get('email'));
        const password = String(f.get('password'));
        const err = $('auth-error'); const ok = $('auth-ok');
        err.classList.add('hidden'); ok.classList.add('hidden');

        if (mode === 'signup') {
          const { data, error } = await sb!.auth.signUp({ email, password });
          if (error) { err.textContent = error.message; err.classList.remove('hidden'); return; }
          if (data.session) done();
          else { ok.textContent = 'Account created. Check your email to confirm, then sign in.'; ok.classList.remove('hidden'); }
          return;
        }
        const { error } = await sb!.auth.signInWithPassword({ email, password });
        if (error) { err.textContent = error.message; err.classList.remove('hidden'); }
        else done();
      });

      function done() {
        if (next) location.href = next;
        else showAccount();
      }
    }

    async function showAccount() {
      ($('auth') as HTMLElement).classList.add('hidden');
      $('account').classList.remove('hidden');
      const { data: { user } } = await sb!.auth.getUser();
      $('acct-email').textContent = user?.email ?? '';
      $('acct-signout').addEventListener('click', async () => { await sb!.auth.signOut(); location.reload(); });
      loadOrders();
    }

    async function loadOrders() {
      const status = $('orders-status');
      const { data, error } = await sb!.from('orders').select('*').order('created_at', { ascending: false });
      if (error) { status.textContent = error.message; return; }
      if (!data!.length) { status.textContent = 'No orders yet.'; $('orders').innerHTML = ''; return; }
      status.textContent = `${data!.length} order${data!.length === 1 ? '' : 's'}`;
      $('orders').innerHTML = data!.map((o: any) => {
        const items = (o.items || []).map((i: any) => `${i.qty}× ${i.name} ${i.size}`).join(', ');
        const date = new Date(o.created_at).toLocaleDateString('en-CA', { month: 'short', day: '2-digit', year: 'numeric' });
        const ful = o.customer?.fulfilment ? ` · ${o.customer.fulfilment}` : '';
        return `<div class="grid grid-cols-1 gap-2 rounded-xl border border-black/10 bg-white p-4 sm:grid-cols-[140px_1fr_90px_120px] sm:items-center">
          <div><p class="font-mono font-bold text-ink">${o.ref}</p><p class="text-[11px] text-steel">${date}${ful}</p></div>
          <div class="text-sm text-steel">${items}</div>
          <div class="font-display text-lg font-bold text-ink">$${o.total}</div>
          <div class="sm:text-right"><span class="inline-flex items-center gap-1.5 rounded-md bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700"><span class="h-2 w-2 rounded-full bg-amber-500"></span>${o.status}</span></div>
        </div>`;
      }).join('');
    }
  </script>
</Layout>
