---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProductSchema from '../components/ProductSchema.astro';
import Icon from '../components/Icon.astro';
import { formatStock, sizeCode } from '../data/products';
import { getTires, brandsOf, seasonsOf } from '../lib/inventory';
import { site, delivery } from '../data/site';

// Live from Supabase when configured, else the bundled inventory.json.
const products = await getTires();
const brandsInStock = brandsOf(products);
const seasonsInStock = seasonsOf(products);

// Online card payment (Stripe) is available when the publishable key is set.
const paymentsEnabled = Boolean(import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY);

const minPrice = Math.min(...products.map((p) => p.price));

const seasonIcon: Record<string, string> = {
  Winter: 'snow',
  'All-Weather': 'globe',
  'All-Season': 'sun',
  Summer: 'sun',
};

// Attribute flag chips rendered under each tire's description.
const flagsOf = (p: (typeof products)[number]) =>
  [
    p.ev && { label: 'EV', icon: 'bolt' },
    p.runFlat && { label: 'Run-flat', icon: 'shield' },
    p.studdable && { label: 'Studdable', icon: 'snow' },
    p.onSale && { label: 'On sale', icon: 'tag' },
  ].filter(Boolean) as { label: string; icon: string }[];
---

<Layout
  title={`Shop Tires in ${site.city} — Search ${products.length}+ Sizes In Stock`}
  description={`Search ${site.city} tire inventory by size (e.g. 2055516) or brand. Honest pricing from $${minPrice}, live stock, and add-to-order. Delivery on ${delivery.minTires}+ tires.`}
>
  <PageHeader eyebrow="Live · Edmonton stock" title="Search & order tires.">
    Type your size (e.g. <span class="font-mono">2055516</span>) or a brand,
    filter, and add to your order. Honest tire prices — no hidden fees.
    Get {delivery.minTires}+ delivered anywhere in {site.city}.
  </PageHeader>

  <Breadcrumbs items={[{ label: 'Shop tires', href: '/shop' }]} />

  <section class="bg-mist py-10 sm:py-14">
    <div class="container-px">
      <!-- Search + filter panel -->
      <form id="filters" class="rounded-2xl border border-black/10 bg-white p-5 shadow-sm sm:p-6" role="search">
        <div class="flex flex-col gap-3 sm:flex-row">
          <div class="relative flex-1">
            <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center">
              <Icon name="search" class="h-5 w-5 text-steel" />
            </span>
            <input
              id="q"
              type="text"
              autocomplete="off"
              placeholder="Search by size (2055516) or brand — e.g. “Michelin”"
              class="w-full rounded-lg border border-black/10 bg-white py-3 pl-11 pr-4 text-base outline-none focus:border-brand focus:ring-2 focus:ring-brand/30"
            />
          </div>
          <button type="button" id="clear" class="rounded-lg border border-black/15 px-5 py-3 text-sm font-semibold text-steel transition-colors hover:bg-mist">
            Clear
          </button>
        </div>

        <!-- Filter controls -->
        <div class="mt-4 grid gap-4 border-t border-black/5 pt-4 lg:grid-cols-[220px_1fr]">
          <label class="block">
            <span class="text-xs font-bold uppercase tracking-widest text-steel">Manufacturer</span>
            <select id="brand" class="mt-1.5 w-full rounded-lg border border-black/10 bg-white px-3 py-2.5 text-sm outline-none focus:border-brand focus:ring-2 focus:ring-brand/30">
              <option value="">All brands</option>
              {brandsInStock.map((b) => <option value={b}>{b}</option>)}
            </select>
          </label>

          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-steel">Season</span>
            <div class="mt-1.5 flex flex-wrap gap-2">
              <button type="button" data-season="All" class="season-chip is-active">All</button>
              {seasonsInStock.map((s) => (
                <button type="button" data-season={s} class="season-chip">{s}</button>
              ))}
            </div>
          </div>
        </div>

        <!-- Attribute toggles -->
        <div class="mt-4 flex flex-wrap gap-2">
          {[
            { key: 'sale', label: 'On sale' },
            { key: 'ev', label: 'EV-ready' },
            { key: 'runflat', label: 'Run-flat' },
            { key: 'studdable', label: 'Studdable' },
          ].map((t) => (
            <label class="toggle-chip">
              <input type="checkbox" data-toggle={t.key} class="peer sr-only" />
              <span class="peer-checked:hidden"><Icon name="plus" class="h-3.5 w-3.5" /></span>
              <span class="hidden peer-checked:inline"><Icon name="check" class="h-3.5 w-3.5" /></span>
              {t.label}
            </label>
          ))}
        </div>
      </form>

      <!-- Toolbar -->
      <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
        <p class="text-sm font-medium text-steel">
          <span id="count">{products.length}</span> results ·
          <span class="text-emerald-600">{site.stockCount}+ in stock</span>
        </p>
        <label class="flex items-center gap-2 text-sm text-steel">
          Sort
          <select id="sort" class="rounded-lg border border-black/10 bg-white px-3 py-2 text-sm outline-none focus:border-brand">
            <option value="featured">Featured</option>
            <option value="price-asc">Price: low to high</option>
            <option value="price-desc">Price: high to low</option>
            <option value="stock">In stock first</option>
          </select>
        </label>
      </div>

      <!-- Column header (desktop) -->
      <div class="mt-4 hidden rounded-t-xl bg-ink px-5 py-3 text-xs font-bold uppercase tracking-widest text-white/70 md:grid md:grid-cols-[140px_1fr_84px_160px_120px_150px] md:gap-4">
        <span>Size</span><span>Description</span><span>Spec</span><span>Price</span><span>On hand</span><span class="text-right">Order</span>
      </div>

      <!-- Results -->
      <div id="results" class="overflow-hidden rounded-b-xl border border-black/10 bg-white md:border-t-0">
        {
          products.map((p, i) => {
            const out = p.stock === 0;
            return (
              <div
                class="trow grid grid-cols-1 gap-3 border-b border-black/[0.06] px-5 py-4 last:border-0 md:grid-cols-[140px_1fr_84px_160px_120px_150px] md:items-center md:gap-4"
                data-id={p.id}
                data-code={sizeCode(p.size)}
                data-text={`${p.brand} ${p.model} ${p.size}`.toLowerCase()}
                data-brand={p.brand}
                data-season={p.season}
                data-price={p.price}
                data-stock={p.stock}
                data-sku={p.sku}
                data-size={p.size}
                data-name={`${p.brand} ${p.model}`}
                data-featured={i}
                data-sale={p.onSale ? '1' : ''}
                data-ev={p.ev ? '1' : ''}
                data-runflat={p.runFlat ? '1' : ''}
                data-studdable={p.studdable ? '1' : ''}
              >
                <div class="min-w-0">
                  <p class="font-display text-lg font-bold text-ink">{p.size}</p>
                  <p class="font-mono text-[11px] text-steel">{p.sku}</p>
                </div>

                <div class="min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-mist text-brand">
                      <Icon name={seasonIcon[p.season]} class="h-4 w-4" />
                    </span>
                    <p class="truncate font-semibold text-ink">
                      {p.brand} <span class="font-normal text-steel">{p.model}</span>
                    </p>
                    {p.bestSeller && (
                      <span class="rounded-full bg-brand/10 px-2 py-0.5 text-[10px] font-bold uppercase text-brand">Top</span>
                    )}
                  </div>
                  <div class="mt-1.5 flex flex-wrap gap-1.5">
                    {flagsOf(p).map((f) => (
                      <span class="inline-flex items-center gap-1 rounded-md bg-mist px-1.5 py-0.5 text-[11px] font-medium text-steel">
                        <Icon name={f.icon} class="h-3 w-3" />{f.label}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="text-sm text-steel">
                  <span class="md:hidden text-xs font-semibold uppercase tracking-wide">Load/speed: </span>
                  <span class="font-mono">{p.loadIndex}{p.speedRating}</span>
                </div>

                <div>
                  <span class="font-display text-2xl font-bold text-ink">${p.price}</span>
                  <span class="ml-1 text-xs text-steel line-through">${p.msrp}</span>
                  <span class="block text-[11px] font-semibold text-emerald-600">
                    save ${p.msrp - p.price}
                  </span>
                </div>

                <div class="stock-cell" data-id={p.id}>
                  {out ? (
                    <span class="inline-flex items-center gap-1.5 rounded-md bg-brand/10 px-2.5 py-1 text-xs font-bold text-brand">
                      Call for availability
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1.5 rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700">
                      <span class="h-2 w-2 rounded-full bg-emerald-500" />
                      {formatStock(p.stock)} on hand
                    </span>
                  )}
                </div>

                <div class="order-cell md:text-right" data-id={p.id}>
                  {out ? (
                    <a href={`mailto:${site.email}?subject=${encodeURIComponent(`Availability: ${p.sku}`)}`} class="btn-dark w-full py-2 text-sm md:w-auto">
                      Enquire
                    </a>
                  ) : (
                    <button type="button" class="add-btn btn-dark w-full py-2 text-sm group-hover:bg-brand md:w-auto" data-id={p.id}>
                      Add to order
                    </button>
                  )}
                </div>
              </div>
            );
          })
        }
      </div>

      <p id="empty" class="hidden rounded-xl border border-dashed border-black/15 bg-white p-10 text-center text-steel">
        No tires match. Try a different size or brand, or
        <a href={`mailto:${site.email}`} class="font-semibold text-brand">email us</a> — we restock daily.
      </p>
    </div>
  </section>

  <!-- Sticky order bar -->
  <div id="order-bar" class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-white/10 bg-ink text-white transition-transform duration-300" hidden>
    <div class="container-px flex flex-wrap items-center justify-between gap-3 py-3.5">
      <div class="flex items-center gap-3">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand">
          <Icon name="cart" class="h-5 w-5" />
        </span>
        <p class="text-sm">
          <span id="order-qty" class="font-bold">0</span> tires in order ·
          <span id="order-total" class="font-bold">$0</span>
          <span id="order-hint" class="block text-xs text-white/50"></span>
        </p>
      </div>
      <div class="flex items-center gap-2">
        <button type="button" id="order-clear" class="rounded-lg px-3 py-2 text-sm text-white/70 hover:text-white">Clear</button>
        <button type="button" id="order-request" class="btn-primary py-2.5 text-sm" data-email={site.email}>Checkout</button>
      </div>
    </div>
  </div>

  <!-- Checkout modal (delivery details) -->
  <div id="checkout" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl">
      <div class="flex items-center justify-between">
        <h2 class="heading text-2xl text-ink">Your order</h2>
        <button id="checkout-close" class="text-2xl leading-none text-steel hover:text-ink">&times;</button>
      </div>
      <p id="checkout-summary" class="mt-1 text-sm text-steel"></p>

      <form id="checkout-form" class="mt-4 space-y-3">
        <div class="grid grid-cols-2 gap-2">
          <label class="fulfil-opt"><input type="radio" name="fulfilment" value="Delivery" checked class="peer sr-only" /><span class="block rounded-lg border border-black/10 px-3 py-2.5 text-center text-sm font-semibold peer-checked:border-brand peer-checked:bg-brand peer-checked:text-white">Delivery</span></label>
          <label class="fulfil-opt"><input type="radio" name="fulfilment" value="Pickup" class="peer sr-only" /><span class="block rounded-lg border border-black/10 px-3 py-2.5 text-center text-sm font-semibold peer-checked:border-brand peer-checked:bg-brand peer-checked:text-white">Pickup</span></label>
        </div>
        <input name="name" placeholder="Full name" required class="form-field !mt-0" />
        <input name="phone" type="tel" placeholder="Phone" required class="form-field !mt-0" />
        <textarea id="address" name="address" rows="2" placeholder="Delivery address in Edmonton" class="form-field !mt-0"></textarea>

        {paymentsEnabled && (
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-steel">Payment</span>
            <div class="mt-1.5 grid grid-cols-2 gap-2">
              <label class="pay-opt"><input type="radio" name="pay" value="online" checked class="peer sr-only" /><span class="block rounded-lg border border-black/10 px-3 py-2.5 text-center text-sm font-semibold peer-checked:border-brand peer-checked:bg-brand peer-checked:text-white">Pay online (card)</span></label>
              <label class="pay-opt"><input type="radio" name="pay" value="cod" class="peer sr-only" /><span class="block rounded-lg border border-black/10 px-3 py-2.5 text-center text-sm font-semibold peer-checked:border-brand peer-checked:bg-brand peer-checked:text-white">Pay on delivery</span></label>
            </div>
          </div>
        )}

        <p id="checkout-error" class="hidden text-sm font-medium text-brand"></p>
        <button type="submit" id="checkout-submit" class="btn-primary w-full">Place order</button>
        <p class="text-center text-xs text-steel">Card payments are processed securely by Stripe (Visa, Mastercard, Amex &amp; debit). You’ll get a reference to track your order.</p>
      </form>

      <div id="checkout-done" class="hidden text-center">
        <p class="mt-2 text-lg font-semibold text-ink">Order placed 🎉</p>
        <p class="mt-1 text-sm text-steel">Reference <span id="done-ref" class="font-mono font-bold text-ink"></span>. We’ll call to confirm.</p>
        <a href="/account" class="btn-dark mt-4 inline-flex">View my orders</a>
      </div>
    </div>
  </div>

  <ProductSchema products={products} />

  <style>
    .season-chip {
      border-radius: 9999px;
      border: 1px solid rgba(0, 0, 0, 0.1);
      padding: 0.375rem 0.85rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-steel);
      transition: all 0.15s ease;
    }
    .season-chip.is-active {
      border-color: var(--color-brand);
      background: var(--color-brand);
      color: #fff;
    }
    .toggle-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      cursor: pointer;
      border-radius: 9999px;
      border: 1px solid rgba(0, 0, 0, 0.1);
      padding: 0.35rem 0.75rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-steel);
      transition: all 0.15s ease;
    }
    .toggle-chip:has(input:checked) {
      border-color: var(--color-brand);
      background: color-mix(in srgb, var(--color-brand) 8%, white);
      color: var(--color-brand);
    }
  </style>

  <script>
    import { getSupabase } from '../lib/supabase';
    const supabase = getSupabase();

    type OrderItem = { sku: string; name: string; size: string; price: number; qty: number };
    const KEY = 'axel-order';

    const $ = <T extends HTMLElement>(s: string, r: ParentNode = document) => r.querySelector<T>(s);
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.trow'));
    const resultsEl = document.getElementById('results')!;
    const countEl = document.getElementById('count')!;
    const emptyEl = document.getElementById('empty')!;
    const q = $('#q') as HTMLInputElement;
    const brandSel = $('#brand') as HTMLSelectElement;
    const sortSel = $('#sort') as HTMLSelectElement;
    const seasonChips = Array.from(document.querySelectorAll<HTMLButtonElement>('.season-chip'));
    const toggles = Array.from(document.querySelectorAll<HTMLInputElement>('[data-toggle]'));

    let season = 'All';

    // ---- Filtering + sorting ----
    function apply() {
      const raw = q.value.trim().toLowerCase();
      const digits = raw.replace(/[^0-9]/g, '');
      const text = raw.replace(/[0-9/]/g, '').trim();
      const brand = brandSel.value;
      const on = (k: string) => toggles.find((t) => t.dataset.toggle === k)?.checked;

      let shown = 0;
      rows.forEach((row) => {
        const d = row.dataset;
        const okCode = !digits || (d.code || '').includes(digits);
        const okText = !text || (d.text || '').includes(text);
        const okBrand = !brand || d.brand === brand;
        const okSeason = season === 'All' || d.season === season;
        const okSale = !on('sale') || d.sale === '1';
        const okEv = !on('ev') || d.ev === '1';
        const okRf = !on('runflat') || d.runflat === '1';
        const okStud = !on('studdable') || d.studdable === '1';
        const vis = okCode && okText && okBrand && okSeason && okSale && okEv && okRf && okStud;
        row.classList.toggle('hidden', !vis);
        if (vis) shown++;
      });
      countEl.textContent = String(shown);
      emptyEl.classList.toggle('hidden', shown !== 0);

      // Sort visible rows by reordering DOM.
      const s = sortSel.value;
      const sorted = [...rows].sort((a, b) => {
        if (s === 'price-asc') return +a.dataset.price! - +b.dataset.price!;
        if (s === 'price-desc') return +b.dataset.price! - +a.dataset.price!;
        if (s === 'stock') return +b.dataset.stock! - +a.dataset.stock!;
        return +a.dataset.featured! - +b.dataset.featured!;
      });
      sorted.forEach((row) => resultsEl.appendChild(row));
    }

    q.addEventListener('input', apply);
    brandSel.addEventListener('change', apply);
    sortSel.addEventListener('change', apply);
    document.getElementById('clear')!.addEventListener('click', () => {
      q.value = '';
      brandSel.value = '';
      toggles.forEach((t) => (t.checked = false));
      season = 'All';
      seasonChips.forEach((c) => c.classList.toggle('is-active', c.dataset.season === 'All'));
      apply();
    });
    seasonChips.forEach((chip) =>
      chip.addEventListener('click', () => {
        season = chip.dataset.season || 'All';
        seasonChips.forEach((c) => c.classList.toggle('is-active', c === chip));
        apply();
      }),
    );
    toggles.forEach((t) => t.addEventListener('change', apply));

    // Pre-fill ?size= from the homepage size finder.
    const initial = new URLSearchParams(location.search).get('size');
    if (initial) {
      q.value = initial;
      apply();
    }

    // ---- Order builder ----
    const load = (): Record<string, OrderItem> => {
      try {
        return JSON.parse(localStorage.getItem(KEY) || '{}');
      } catch {
        return {};
      }
    };
    const save = (o: Record<string, OrderItem>) => localStorage.setItem(KEY, JSON.stringify(o));
    let order = load();

    const bar = document.getElementById('order-bar')!;
    const qtyEl = document.getElementById('order-qty')!;
    const totalEl = document.getElementById('order-total')!;
    const hintEl = document.getElementById('order-hint')!;
    const MIN = 2; // delivery minimum

    function renderCell(id: string) {
      const cell = document.querySelector<HTMLElement>(`.order-cell[data-id="${id}"]`);
      if (!cell) return;
      const item = order[id];
      if (!item) {
        cell.innerHTML = `<button type="button" class="add-btn btn-dark w-full py-2 text-sm md:w-auto" data-id="${id}">Add to order</button>`;
      } else {
        cell.innerHTML = `
          <div class="inline-flex items-center rounded-lg border border-black/10 md:ml-auto">
            <button type="button" class="step h-9 w-9 text-lg font-bold text-steel hover:text-brand" data-id="${id}" data-step="-1">−</button>
            <span class="w-8 text-center font-bold text-ink">${item.qty}</span>
            <button type="button" class="step h-9 w-9 text-lg font-bold text-steel hover:text-brand" data-id="${id}" data-step="1">+</button>
          </div>`;
      }
    }

    function renderBar() {
      const items = Object.values(order);
      const qty = items.reduce((n, i) => n + i.qty, 0);
      const total = items.reduce((n, i) => n + i.qty * i.price, 0);
      qtyEl.textContent = String(qty);
      totalEl.textContent = `$${total.toLocaleString()}`;
      hintEl.textContent = qty > 0 && qty < MIN ? `Add ${MIN - qty} more tire for Edmonton delivery` : '';
      if (qty > 0) {
        bar.hidden = false;
        requestAnimationFrame(() => bar.classList.remove('translate-y-full'));
        document.body.style.paddingBottom = '76px';
      } else {
        bar.classList.add('translate-y-full');
        document.body.style.paddingBottom = '';
        setTimeout(() => (bar.hidden = qty === 0), 300);
      }
    }

    function addToOrder(id: string) {
      const row = document.querySelector<HTMLElement>(`.trow[data-id="${id}"]`);
      if (!row) return;
      const d = row.dataset;
      const cur = order[id]?.qty || 0;
      order[id] = { sku: d.sku!, name: `${d.name} ${d.size}`, size: d.size!, price: +d.price!, qty: cur + 1 };
      save(order);
      renderCell(id);
      renderBar();
    }
    function step(id: string, delta: number) {
      if (!order[id]) return;
      order[id].qty += delta;
      if (order[id].qty <= 0) delete order[id];
      save(order);
      renderCell(id);
      renderBar();
    }

    // Guests must have an account before building an order — send them to
    // sign up on the first "Add to order" click.
    async function requireAccount(): Promise<boolean> {
      if (!supabase) return true; // no backend configured → email fallback flow
      const { data } = await supabase.auth.getSession();
      if (data.session) return true;
      location.href = '/account?reason=order&next=/shop';
      return false;
    }

    // Event delegation for add / stepper.
    document.addEventListener('click', async (e) => {
      const t = e.target as HTMLElement;
      const add = t.closest<HTMLElement>('.add-btn');
      if (add) {
        if (await requireAccount()) addToOrder(add.dataset.id!);
        return;
      }
      const s = t.closest<HTMLElement>('.step');
      if (s) return step(s.dataset.id!, +s.dataset.step!);
    });

    document.getElementById('order-clear')!.addEventListener('click', () => {
      order = {};
      save(order);
      rows.forEach((r) => renderCell(r.dataset.id!));
      renderBar();
    });

    const requestBtn = document.getElementById('order-request') as HTMLElement;
    const EMAIL = requestBtn.dataset.email || '';
    const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    const checkout = document.getElementById('checkout')!;
    const checkoutForm = document.getElementById('checkout-form') as HTMLFormElement;
    const addressEl = document.getElementById('address') as HTMLTextAreaElement;

    // Show/require the address only for delivery.
    checkoutForm.querySelectorAll<HTMLInputElement>('input[name="fulfilment"]').forEach((r) =>
      r.addEventListener('change', () => {
        const delivery = (checkoutForm.querySelector('input[name="fulfilment"]:checked') as HTMLInputElement).value === 'Delivery';
        addressEl.classList.toggle('hidden', !delivery);
        addressEl.required = delivery;
      }),
    );

    function openCheckout() {
      const items = Object.values(order);
      const qty = items.reduce((n, i) => n + i.qty, 0);
      const total = items.reduce((n, i) => n + i.qty * i.price, 0);
      document.getElementById('checkout-summary')!.textContent = `${qty} tires · $${total.toLocaleString()}`;
      checkout.classList.remove('hidden');
      checkout.classList.add('flex');
    }
    function closeCheckout() { checkout.classList.add('hidden'); checkout.classList.remove('flex'); }
    document.getElementById('checkout-close')!.addEventListener('click', closeCheckout);
    checkout.addEventListener('click', (e) => { if (e.target === checkout) closeCheckout(); });

    // Checkout button: require an account, then open the details modal.
    requestBtn.addEventListener('click', async () => {
      if (!Object.values(order).length) return;

      // No backend configured → fall back to an email order request.
      if (!SB_URL || !SB_KEY || !supabase) {
        emailFallback();
        return;
      }
      const { data } = await supabase.auth.getSession();
      if (!data.session) {
        // Send them to sign in / sign up, then straight back to the cart.
        location.href = '/account?reason=order&next=/shop';
        return;
      }
      openCheckout();
    });

    // Reflect the chosen payment method in the button label.
    const submitBtn = document.getElementById('checkout-submit') as HTMLButtonElement;
    const payMethod = () =>
      (checkoutForm.querySelector('input[name="pay"]:checked') as HTMLInputElement | null)?.value ?? 'cod';
    checkoutForm.querySelectorAll<HTMLInputElement>('input[name="pay"]').forEach((r) =>
      r.addEventListener('change', () => {
        submitBtn.textContent = payMethod() === 'online' ? 'Pay now →' : 'Place order';
      }),
    );
    if (payMethod() === 'online') submitBtn.textContent = 'Pay now →';

    checkoutForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const err = document.getElementById('checkout-error')!;
      err.classList.add('hidden');
      const f = new FormData(checkoutForm);
      const items = Object.values(order);
      const total = items.reduce((n, i) => n + i.qty * i.price, 0);
      const customer = {
        name: f.get('name'), phone: f.get('phone'),
        fulfilment: f.get('fulfilment'), address: f.get('address') || '',
      };

      // ── Pay online: create a Stripe Checkout session and redirect ──
      if (payMethod() === 'online') {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Redirecting…';
        const { data: { session } } = await supabase!.auth.getSession();
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: items.map((i) => ({ sku: i.sku, qty: i.qty })),
            customer,
            token: session?.access_token,
          }),
        }).then((r) => r.json()).catch(() => ({ error: 'Network error.' }));
        if (res?.url) { location.href = res.url; return; }
        err.textContent = res?.error || 'Could not start payment.';
        err.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Pay now →';
        return;
      }

      // ── Pay on delivery/pickup: save the order directly ──
      const ref = 'AX-' + String(Date.now()).slice(-6);
      const { data: { user } } = await supabase!.auth.getUser();
      const { error } = await supabase!.from('orders').insert({
        ref, user_id: user?.id, items, total, status: 'Requested', customer,
      });
      if (error) { err.textContent = error.message; err.classList.remove('hidden'); return; }

      order = {};
      save(order);
      rows.forEach((r) => renderCell(r.dataset.id!));
      renderBar();
      checkoutForm.classList.add('hidden');
      document.getElementById('done-ref')!.textContent = ref;
      document.getElementById('checkout-done')!.classList.remove('hidden');
    });

    function emailFallback() {
      const items = Object.values(order);
      const lines = items.map((i) => `• ${i.qty}× ${i.name} (${i.sku}) — $${i.price} ea.`);
      const total = items.reduce((n, i) => n + i.qty * i.price, 0);
      const ref = 'AX-' + String(Date.now()).slice(-6);
      const body = [
        `Order reference: ${ref}`, '', 'I’d like to order:', '', ...lines, '',
        `Subtotal: $${total}`, '', 'Name:', 'Phone:', 'Pickup or delivery (Edmonton):',
      ].join('\n');
      location.href = `mailto:${EMAIL}?subject=${encodeURIComponent('Tire order ' + ref)}&body=${encodeURIComponent(body)}`;
    }

    // Hydrate existing order on load.
    rows.forEach((r) => order[r.dataset.id!] && renderCell(r.dataset.id!));
    renderBar();

    // Live stock: refresh on-hand counts + prices from Supabase after load.
    // (SB_URL / SB_KEY are declared above near the checkout handler.)
    if (SB_URL && SB_KEY) {
      fetch(`${SB_URL}/rest/v1/tires_public?select=id,stock,price,msrp`, {
        headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` },
      })
        .then((r) => (r.ok ? r.json() : []))
        .then((live: { id: string; stock: number; price: number; msrp: number }[]) => {
          live.forEach((t) => {
            const row = document.querySelector<HTMLElement>(`.trow[data-id="${t.id}"]`);
            if (!row) return;
            row.dataset.stock = String(t.stock);
            row.dataset.price = String(t.price);
            const cell = row.querySelector<HTMLElement>('.stock-cell');
            if (cell) {
              cell.innerHTML =
                t.stock <= 0
                  ? '<span class="inline-flex items-center gap-1.5 rounded-md bg-brand/10 px-2.5 py-1 text-xs font-bold text-brand">Call for availability</span>'
                  : `<span class="inline-flex items-center gap-1.5 rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700"><span class="h-2 w-2 rounded-full bg-emerald-500"></span>${t.stock >= 12 ? '12+' : t.stock} on hand</span>`;
            }
          });
        })
        .catch(() => {});
    }
  </script>
</Layout>
