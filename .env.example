# Copy to `.env` (local) and add the same vars in Vercel →
# Project → Settings → Environment Variables.

# ── Supabase (public/anon — safe in the browser; DB protected by RLS) ──
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── Stripe payments ──
# Public: shows the "Pay online" option and is safe in the browser.
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
# SECRET — server only. NEVER expose these to the browser or commit real values.
STRIPE_SECRET_KEY=sk_live_or_test_xxx
# Supabase service role key — server only, lets the payment function mark orders
# paid. Get it from Supabase → Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET
