# Supabase — copy to `.env` (local) and add the same vars in Vercel →
# Project → Settings → Environment Variables. Both are PUBLIC/anon values and
# are safe in the browser; the database is protected by Row Level Security.
# NEVER put the Supabase service_role/secret key here.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
